# Oracle price pusher — ARCH MAINNET.
#
# Deploy the container image with these env vars (e.g. a Railway service).
# Same image/entrypoint as testnet; only the values below differ.
#
# ORACLE_PROGRAM_ID is the mainnet oracle program from the deploy artifact
# (deployments/*.json -> oracle_id).

ROLE=pusher
NETWORK=mainnet
ARCH_RPC_URL=https://rpc.mainnet.arch.network
ORACLE_PROGRAM_ID=a2b2fe9e9f8a7122c88f091224333db15f7347671577c8552b93dd7640b6f98d

# Feeds to push. The aUSD/aBTC market needs BTC + USDC.
FEEDS=0xe62df6c8b4a85fe1a67db44dc12de5db330f7ac66b72dc658afedf0f4a415b43,0xeaa020c61cc479712813461ce153894a96a6c00b21ed0cfc2798d1f9a9e9c94a

# SIGNER_KEY_B64 is REQUIRED on mainnet — there is no faucet. Provide the base64
# of a hex secret-key file for a DEDICATED, PRE-FUNDED signer (any key works;
# the oracle program only needs a signature). Keep it topped up for tx fees and
# alert on its balance — if it runs dry, pushes stop and markets fail with
# OracleRateTooOld (0x1b70).
# SIGNER_KEY_B64=<base64 of a hex secret-key file>  # set as a Railway secret
