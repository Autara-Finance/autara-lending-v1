# Autara testnet deploy env — aUSD/aBTC market on the NEW testnet program line.
#
# Target program id: 34cf72a92dd76322a42f13f99e51cf7c03221f4adbd4ee7e0c409c4161dfe20c
# (compiled into autara_program::id()). The PROGRAM_KEY_PATH below MUST be the
# keypair whose pubkey equals that id — the preflight program-id guard enforces
# this (fatal on a real run).
#
# Tokens reuse the EXISTING CLAMM testnet APL mints (NO new mints are created):
#   aBTC  decimals 8  mint 627ecd24366c89314b12aa08a1b2fffc3890cb9cf64fb04fe3e95c7182b23dfb
#   aUSD  decimals 6  mint 8ec480c6e5458e7d37dc2a9f7d7d149a02d8182a38523b037905203ff36b71f6
# Market: aUSD/aBTC (supply = aUSD, collateral = aBTC), mirroring CLAMM USDC/BTC.
#
# Only PATHS live here — never secrets.

NETWORK=testnet
ARCH_RPC_URL=https://rpc.testnet.arch.network
USE_FAUCET=true

# autara-program: pubkey MUST equal autara_program::id() (34cf72…). Keep this key
# in the gitignored .keys-testnet/ dir (synced by sync-program-id.sh upstream).
PROGRAM_KEY_PATH=autara-deploy/.keys-testnet/program.json
# autara-oracle: position-independent (uses the runtime program_id only).
ORACLE_KEY_PATH=autara-deploy/.keys-testnet/oracle.json
# Program upgrade authority + payer for the ELF uploads.
DEPLOYER_KEY_PATH=autara-deploy/.keys-testnet/deployer.json
# Global-config admin (also payer/signer for create_global_config + curator).
ADMIN_KEY_PATH=autara-deploy/.keys-testnet/admin.json

PROGRAM_ELF_PATH=target/deploy/autara_program.so
ORACLE_ELF_PATH=target/deploy/autara_oracle.so

PROTOCOL_FEE_SHARE_BPS=5000

# Tokens: LABEL:MINT_HEX:DECIMALS[:MINT_AMOUNT[:FAUCET_AMOUNT]] (raw units).
# Both amounts default to 1_000_000_000_000 (CLAMM TEST_MINT_AMOUNT); set here
# explicitly for clarity. MINT_AMOUNT is the initial supply the (opt-in) deploy
# mint step mints to the authority; FAUCET_AMOUNT documents the server faucet.
TOKENS=aUSD:8ec480c6e5458e7d37dc2a9f7d7d149a02d8182a38523b037905203ff36b71f6:6:1000000000000:1000000000000,aBTC:627ecd24366c89314b12aa08a1b2fffc3890cb9cf64fb04fe3e95c7182b23dfb:8:1000000000000:1000000000000

# Lending market(s): SUPPLY/COLLATERAL by label.
MARKET_PAIRS=aUSD/aBTC
LENDING_MARKET_FEE_BPS=100

# ---- Initial-supply minting (OPT-IN; off by default) -----------------------
# The mint step is gated by STEP_MINT_INITIAL_SUPPLY (default false) AND requires
# a mint-authority keypair. It reads each mint on-chain and REFUSES to send if the
# on-chain mint_authority does not match the supplied key (decimals are checked
# too), so a wrong key cannot mint. Supply the authority for the aBTC/aUSD mints
# here before enabling it. Candidate keys (verify which is the live authority):
#   crates/clamm-deploy/.keys-testnet/mint-authorities/aBTC-authority.json  (in the CLAMM repo)
#   crates/clamm-deploy/.keys-testnet/mint-authorities/aUSD-authority.json
#   crates/clamm-deploy/.keys-testnet/authority.json  (pubkey 73ca9f83…; mints both mints in CLAMM's deploy)
# Use a shared key for both, or per-token overrides:
# MINT_AUTHORITY_KEY_PATH=/abs/path/to/clamm/authority.json
# MINT_AUTHORITY_KEY_PATH_ABTC=/abs/path/to/clamm/mint-authorities/aBTC-authority.json
# MINT_AUTHORITY_KEY_PATH_AUSD=/abs/path/to/clamm/mint-authorities/aUSD-authority.json
# STEP_MINT_INITIAL_SUPPLY=true
# MINT_RECIPIENT=<pubkey hex>   # optional; defaults to the authority's own ATA

# Fresh artifact path so a real run never clobbers deployments/testnet.json.
OUTPUT_PATH=deployments/testnet-ausd-abtc.json
