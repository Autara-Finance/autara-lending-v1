# Autara MAINNET deploy env — PRODUCTION.
#
# Mainnet is real value: a REAL run (dry_run=false) is additionally gated in CI
# by the typed confirmation `DEPLOY MAINNET` (see _autara-action.yml) and the
# `mainnet` GitHub Environment (which can require reviewers). This file holds
# ONLY paths — never secrets, never keys.
#
# Every keypair points at the gitignored autara-deploy/.keys-mainnet-prod/ dir
# (the PRODUCTION key set; the earlier .keys-mainnet/ dir belongs to the
# mainnet pipeline TEST RUN and stays untouched). Those files must be
# provisioned out-of-band (NEVER generated or committed here). The program
# key's pubkey must equal autara_program::id() (kept in sync by
# autara-deploy/scripts/sync-program-id.sh + an ELF rebuild).

NETWORK=mainnet
ARCH_RPC_URL=https://rpc.mainnet.arch.network
# No faucet on mainnet — fund the deployer + admin out-of-band.
USE_FAUCET=false

# autara-program: pubkey must equal autara_program::id().
PROGRAM_KEY_PATH=autara-deploy/.keys-mainnet-prod/program.json
# autara-oracle: position-independent (uses the runtime program_id only).
ORACLE_KEY_PATH=autara-deploy/.keys-mainnet-prod/oracle.json
# Program upgrade authority + payer for the ELF uploads.
DEPLOYER_KEY_PATH=autara-deploy/.keys-mainnet-prod/deployer.json
# Global-config admin (also payer/signer for create_global_config + market curator).
ADMIN_KEY_PATH=autara-deploy/.keys-mainnet-prod/admin.json

PROGRAM_ELF_PATH=target/deploy/autara_program.so
ORACLE_ELF_PATH=target/deploy/autara_oracle.so

PROTOCOL_FEE_SHARE_BPS=5000

# ============================ MAINNET TOKEN MINTS ============================
# PRODUCTION mints for the real mainnet deploy.
#   aUSD (supply/quote):  aec8ca1598d74bc27721536f1a88b5648740bc6a856546a0a47817ff7fe7437c  decimals=6
#                         (base58: CmHX5TaXPWMqec5HUZUUw27Bs2vGLf2pi6nfReo1Tjj1)
#   aBTC (collateral):    225b03d6f9e05fd834cd18906b019fb46372544b0eeb9f6f8b615472467d46b0  decimals=8
#                         (base58: 3K7Me5gje48mBcNPhWWPxHu2Bood2wmgTPjTeFyvVj5q)
# Token mints (LABEL:MINT_HEX:DECIMALS). Mints are HEX, not base58.
# =============================================================================
TOKENS=aUSD:aec8ca1598d74bc27721536f1a88b5648740bc6a856546a0a47817ff7fe7437c:6,aBTC:225b03d6f9e05fd834cd18906b019fb46372544b0eeb9f6f8b615472467d46b0:8

# Lending markets to create (SUPPLY/COLLATERAL by label). Leave unset to derive
# every ordered pair of TOKENS that has a known Pyth feed.
MARKET_PAIRS=aUSD/aBTC
# Curator/lending fee per market, in basis points.
LENDING_MARKET_FEE_BPS=100

# --- Market economic parameters ----------------------------------------------
# These default (in src/config.rs) to the values below, which mirror
# autara-server's default_market_config and match the historical testnet
# behavior AND the mainnet pipeline test run. PRODUCTION uses the same defaults
# (left commented out => defaults apply); uncomment/adjust only after the team
# agrees on different mainnet risk parameters. The interest-rate curve is
# always adaptive (not parameterized here).
# MARKET_MAX_LTV=0.8            # max borrow LTV a position may open at
# MARKET_UNHEALTHY_LTV=0.9      # LTV at/above which a position is liquidatable
# MARKET_LIQUIDATION_BONUS=0.05 # liquidator bonus (0.001..=0.1 on-chain bounds)
# MARKET_MAX_UTILISATION=0.9    # max supply-vault utilisation after a borrow

OUTPUT_PATH=deployments/mainnet.json
