# Autara testnet deploy env — FRESH / INDEPENDENT deploy.
#
# This variant deploys to BRAND-NEW addresses without touching the existing live
# testnet deployment. It points every keypair at the gitignored
# autara-deploy/.keys-testnet/ dir (auto-generated on first dry-run by the SDK's
# `with_secret_key_file`). Only PATHS live here — never secrets.
#
# The new program key's pubkey is synced into autara_program::id() via
# autara-deploy/scripts/sync-program-id.sh, then the ELF is rebuilt.
#
# Existing live deploy (DO NOT TOUCH): program 53def2dc…1cf64192,
# oracle eee682c2…ed84b15. This env never references keys/ so it cannot collide.

NETWORK=testnet
ARCH_RPC_URL=https://rpc.testnet.arch.network
USE_FAUCET=true

# autara-program: pubkey must equal autara_program::id() (kept in sync by
# sync-program-id.sh + an ELF rebuild). Brand-new key, NOT keys/autara-stage.key.
PROGRAM_KEY_PATH=autara-deploy/.keys-testnet/program.json
# autara-oracle: position-independent (uses the runtime program_id only).
ORACLE_KEY_PATH=autara-deploy/.keys-testnet/oracle.json
# Program upgrade authority + payer for the ELF uploads.
DEPLOYER_KEY_PATH=autara-deploy/.keys-testnet/deployer.json
# Global-config admin (also payer/signer for create_global_config).
ADMIN_KEY_PATH=autara-deploy/.keys-testnet/admin.json

PROGRAM_ELF_PATH=target/deploy/autara_program.so
ORACLE_ELF_PATH=target/deploy/autara_oracle.so

PROTOCOL_FEE_SHARE_BPS=5000

# Token mints from tokens.json (LABEL:MINT_HEX:DECIMALS). Reused as-is: APL mints
# are independent of the lending program id.
TOKENS=BTC:36a97410055bbbdc52b421d0c95f76d85eca066b83db8b14f64665b178c93d8b:8,ETH:7250792453cc3a0bd015778f240dd50b552c48c153b7b83e3ef0c441aff9483c:8,USDC:a80fa79ee82952b0a127f50e7d469dae1a51315d4267ca38d7907ad5df5cb3cb:6

# Lending markets to create (SUPPLY/COLLATERAL by label). Unset => every ordered
# pair of TOKENS with a known Pyth feed.
MARKET_PAIRS=USDC/BTC,USDC/ETH
LENDING_MARKET_FEE_BPS=100

# Fresh artifact path so a real run never clobbers deployments/testnet.json.
OUTPUT_PATH=deployments/testnet-fresh.json
