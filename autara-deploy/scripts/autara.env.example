# =============================================================================
# autara-deploy environment template
# =============================================================================
# Copy to autara-deploy/scripts/autara.<network>.env and fill in. NEVER commit
# real keypairs; only key *paths* live here. Values marked [PER-NETWORK] are the
# only ones that normally differ between networks.

# --- Network & RPC -----------------------------------------------------------
# localnet | testnet | mainnet
NETWORK=testnet
# [PER-NETWORK] Arch RPC endpoint. Defaults to the network's built-in URL if unset.
# ARCH_RPC_URL=https://rpc.testnet.arch.network

# --- Keypair paths (files, not secrets in this file) -------------------------
# [PER-NETWORK] Program, oracle, deployer (program upgrade authority + payer),
# and admin (global-config admin/payer/signer) keypair files.
#
# RECOMMENDED: keep fresh keys in a gitignored dir (see .gitignore). The
# existing repo keys/ files are referenced by the committed testnet env so the
# dry-run works out of the box; rotate to .keys-testnet/ for production.
PROGRAM_KEY_PATH=autara-deploy/.keys-testnet/autara-program.key
ORACLE_KEY_PATH=autara-deploy/.keys-testnet/autara-oracle.key
DEPLOYER_KEY_PATH=autara-deploy/.keys-testnet/autara-deployer.key
ADMIN_KEY_PATH=autara-deploy/.keys-testnet/autara-admin.key

# Compiled program ELFs produced by `cargo-build-sbf --features entrypoint`.
PROGRAM_ELF_PATH=target/deploy/autara_program.so
ORACLE_ELF_PATH=target/deploy/autara_oracle.so

# --- Global config -----------------------------------------------------------
# Admin + fee receiver default to the ADMIN_KEY_PATH keypair's pubkey.
# ADMIN=
# FEE_RECEIVER=
PROTOCOL_FEE_SHARE_BPS=5000

# --- Token mints (recorded in the artifact; wired into markets) --------------
# Comma-separated LABEL:MINT_HEX:DECIMALS. Mints are HEX (arch_program Pubkey),
# not base58.
# TOKENS=BTC:36a97410055bbbdc52b421d0c95f76d85eca066b83db8b14f64665b178c93d8b:8,USDC:a80fa79ee82952b0a127f50e7d469dae1a51315d4267ca38d7907ad5df5cb3cb:6

# --- Markets -----------------------------------------------------------------
# Pairs to create, SUPPLY/COLLATERAL by label. Leave unset to derive every
# ordered pair of TOKENS that has a known Pyth feed (BTC/ETH/USDC).
# MARKET_PAIRS=USDC/BTC,USDC/ETH
# Curator/lending fee per market, in basis points (default 100).
# LENDING_MARKET_FEE_BPS=100

# --- Misc --------------------------------------------------------------------
# Faucet funding (defaults to true on localnet/testnet).
# USE_FAUCET=true
# OUTPUT_PATH=deployments/testnet.json

# --- Step gating (all default true) ------------------------------------------
# STEP_DEPLOY_PROGRAM=true
# STEP_DEPLOY_ORACLE=true
# STEP_INIT_CONFIG=true
# STEP_TOKEN_SETUP=true     # ensure configured mints exist on-chain
# STEP_CREATE_MARKET=true   # create a market per MARKET_PAIRS entry

# --- Dry run -----------------------------------------------------------------
# Equivalent to passing --dry-run. Prints addresses + preflight, sends nothing.
# DRY_RUN=1
