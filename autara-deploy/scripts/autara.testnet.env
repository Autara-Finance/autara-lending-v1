# Autara testnet deploy env.
#
# NOTE: for the dry-run to derive program/oracle ids out of the box, this points
# at the EXISTING repo keys/ files (which match the on-chain autara_program::id).
# For a clean/rotated deploy, copy these into a gitignored autara-deploy/.keys-testnet/
# dir and update the paths below. Only PATHS live here — never secrets.

NETWORK=testnet
ARCH_RPC_URL=https://rpc.testnet.arch.network
USE_FAUCET=true

# autara-program: its pubkey must equal autara_program::id() (the compiled-in id
# used on-chain for global-config PDA derivation + ownership checks).
PROGRAM_KEY_PATH=keys/autara-stage.key
# autara-oracle: position-independent (uses the runtime program_id only).
ORACLE_KEY_PATH=keys/autara-pyth-stage.key
# Program upgrade authority + payer for the ELF uploads.
DEPLOYER_KEY_PATH=keys/autara-deployer.key
# Global-config admin (also payer/signer for create_global_config).
ADMIN_KEY_PATH=keys/autara-admin-stage.key

PROGRAM_ELF_PATH=target/deploy/autara_program.so
ORACLE_ELF_PATH=target/deploy/autara_oracle.so

PROTOCOL_FEE_SHARE_BPS=5000

# Token mints from tokens.json (LABEL:MINT_HEX:DECIMALS).
TOKENS=BTC:36a97410055bbbdc52b421d0c95f76d85eca066b83db8b14f64665b178c93d8b:8,ETH:7250792453cc3a0bd015778f240dd50b552c48c153b7b83e3ef0c441aff9483c:8,USDC:a80fa79ee82952b0a127f50e7d469dae1a51315d4267ca38d7907ad5df5cb3cb:6

# Lending markets to create (SUPPLY/COLLATERAL by label). Unset => every ordered
# pair of TOKENS with a known Pyth feed.
MARKET_PAIRS=USDC/BTC,USDC/ETH
LENDING_MARKET_FEE_BPS=100

OUTPUT_PATH=deployments/testnet.json
