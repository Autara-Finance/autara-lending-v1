# Oracle price pusher — ARCH TESTNET.
#
# Deploy the container image with these env vars (e.g. a Railway service).
# Same image/entrypoint as mainnet; only the values below differ.
#
# ORACLE_PROGRAM_ID must equal the oracle program the testnet markets were
# created against (= pubkey of the deployed autara-pyth-stage key).

ROLE=pusher
NETWORK=testnet
ARCH_RPC_URL=https://rpc.testnet.arch.network
ORACLE_PROGRAM_ID=eee682c27db375bebbc17ed9a76aaa935c8b72bc7de50d736f03e2dfbed84b15

# Feeds to push. aUSD/aBTC markets need BTC + USDC; add ETH if a market uses it.
FEEDS=0xe62df6c8b4a85fe1a67db44dc12de5db330f7ac66b72dc658afedf0f4a415b43,0xeaa020c61cc479712813461ce153894a96a6c00b21ed0cfc2798d1f9a9e9c94a

# SIGNER_KEY_B64 is OPTIONAL on testnet: if unset, the pusher generates a
# throwaway key and funds it from the testnet faucet. Set it (base64 of a hex
# secret-key file) to reuse a stable, pre-funded signer instead.
# SIGNER_KEY_B64=<base64 of a hex secret-key file>
