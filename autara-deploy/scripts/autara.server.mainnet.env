# Autara API/indexer server — ARCH MAINNET (Railway).
#
# Deploy the SAME container image as the pusher; set ROLE=server and these env
# vars. Paths/secrets are injected by Railway — never commit key material.
#
# Checklist before go-live:
#   [ ] PROGRAM_ID matches deployments/mainnet.json -> program_id
#   [ ] ORACLE_PROGRAM_ID matches deployments/mainnet.json -> oracle_id
#   [ ] NETWORK=mainnet (not testnet)
#   [ ] DISABLE_PRICE_PUSHER=1 (dedicated ROLE=pusher service owns pushes)
#   [ ] No testnet leftover mints/program ids in TOKENS_JSON_B64
#   [ ] ARCH_RPC_URL is mainnet

ROLE=server
NETWORK=mainnet
ARCH_RPC_URL=https://rpc.mainnet.arch.network

# REQUIRED on mainnet — do not rely on compiled stage defaults.
# Fill from deployments/mainnet.json after the real deploy.
# PROGRAM_ID=<hex from deployments/mainnet.json program_id>
# ORACLE_PROGRAM_ID=<hex from deployments/mainnet.json oracle_id>
# Current expected oracle (pusher env): a2b2fe9e9f8a7122c88f091224333db15f7347671577c8552b93dd7640b6f98d

# Hand oracle pushing to the dedicated ROLE=pusher service.
DISABLE_PRICE_PUSHER=1

# Optional: base64 of tokens.json for the server's market discovery.
# TOKENS_JSON_B64=<base64>

# Optional: poll this Arch pubkey's lamport balance for pusher-funding alerts
# (emitted as autara_pusher_balance_lamports on :62777/metrics).
# PUSHER_PUBKEY=<hex pubkey of the dedicated pusher signer>
